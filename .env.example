# Firebase Web App (Project settings → Your apps → SDK setup → Config).
# Copy to `.env.local` (gitignored) for local dev / production builds.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Firebase + Google Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# Callable / HTTPS Cloud Functions region (default SDK region if unset).
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# API origin: leave empty for same-origin `/api` (Vite dev proxy).
# VITE_API_BASE=https://api.example.com

# Online Office Desk v2 at / (set 0 to use legacy Gmail-style workspace UI).
# VITE_OFFICE_DESK_V2=1

# Workspace V3 (Teams-style shell). When 1, takes priority over OFFICE_DESK_V2.
# VITE_WORKSPACE_V3=1

# --- Local Firebase emulators (`firebase emulators:start`) ---
# VITE_FIREBASE_USE_EMULATORS=true
# VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
